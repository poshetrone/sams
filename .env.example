# ============================================================
# SAMS — Variables d'environnement
# Copier ce fichier en `.env.local` (ignoré par git) et renseigner les valeurs.
# Sur Vercel : Settings → Environment Variables (recopier les 3 ci-dessous).
# ============================================================

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Clé service-role (SERVEUR UNIQUEMENT — ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY
